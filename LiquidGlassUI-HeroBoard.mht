@charset "utf-8";

body { color: rgb(255, 255, 255); }

h1, h2 { margin: 0px; font-size: initial; font-weight: normal; }

.no-focus-outline :focus { outline: 0px; }

button { margin: 0px; border: 0px; padding: 0px; color: inherit; background-color: transparent; cursor: pointer; }

button:focus-visible { outline: rgb(54, 115, 212) auto 5px !important; border-bottom: none !important; }

button::after { border-bottom: none !important; }

a { color: rgb(255, 255, 255); text-decoration: none; }

a:focus-visible { text-decoration: underline !important; }

button { user-select: none; }

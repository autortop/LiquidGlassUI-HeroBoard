@charset "utf-8";

:root { --glass-bg: rgba(255, 255, 255, 0.15); --glass-bg-hover: rgba(255, 255, 255, 0.25); --glass-border: rgba(255, 255, 255, 0.3); --glass-shadow: rgba(0, 0, 0, 0.1); --primary-blue: #5b8fff; --primary-blue-dark: #4d7fff; --primary-teal: #6dd8d0; --primary-teal-dark: #5bc5bd; --accent-purple: #8b7fff; --accent-purple-dark: #7568ff; --text-primary: #1a202c; --text-secondary: #718096; --text-muted: #a0aec0; --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.06); --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08); --shadow-lg: 0 8px 32px rgba(0, 0, 0, 0.12); --shadow-xl: 0 12px 48px rgba(0, 0, 0, 0.15); --transition-fast: 0.15s cubic-bezier(0.4, 0, 0.2, 1); --transition-base: 0.3s cubic-bezier(0.4, 0, 0.2, 1); --transition-slow: 0.5s cubic-bezier(0.4, 0, 0.2, 1); }

* { margin: 0px; padding: 0px; box-sizing: border-box; }

body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background: linear-gradient(135deg, rgb(224, 231, 255) 0%, rgb(240, 244, 255) 50%, rgb(252, 231, 243) 100%); min-height: 100vh; display: flex; justify-content: center; align-items: center; padding: 20px; }

.container { max-width: 600px; width: 100%; }

.header { text-align: center; margin-bottom: 48px; }

.header h1 { font-size: 2.5rem; font-weight: 700; color: var(--text-primary); margin-bottom: 12px; letter-spacing: -0.02em; }

.header .subtitle { color: var(--text-secondary); font-size: 1.1rem; font-weight: 500; margin-bottom: 8px; }

.header .description { color: var(--text-muted); font-size: 0.9rem; max-width: 500px; margin: 0px auto 16px; line-height: 1.5; }

.header .cta-links { display: flex; gap: 16px; justify-content: center; align-items: center; flex-wrap: wrap; margin-top: 20px; }

.header .cta-link { color: var(--primary-blue); text-decoration: none; font-size: 0.85rem; font-weight: 600; padding: 8px 16px; border-radius: 20px; background: rgba(91, 143, 255, 0.1); transition: all var(--transition-base); display: inline-flex; align-items: center; gap: 6px; }

.header .cta-link:hover { background: rgba(91, 143, 255, 0.2); transform: translateY(-2px); }

.header .badge { display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; background: linear-gradient(135deg, rgba(109, 216, 208, 0.15) 0%, rgba(91, 143, 255, 0.15) 100%); border-radius: 16px; font-size: 0.75rem; color: var(--text-secondary); font-weight: 600; margin-top: 12px; }

.header .badge::before { content: "⚡"; font-size: 1rem; }

.glass { background: linear-gradient(135deg, rgba(255, 255, 255, 0.25) 0%, rgba(255, 255, 255, 0.15) 100%); backdrop-filter: blur(32px) saturate(200%); border: 1.5px solid rgba(255, 255, 255, 0.4); box-shadow: rgba(31, 38, 135, 0.15) 0px 8px 32px, rgba(255, 255, 255, 0.1) 0px 4px 16px, rgba(255, 255, 255, 0.6) 0px 2px 4px inset, rgba(0, 0, 0, 0.08) 0px -3px 6px inset, rgba(255, 255, 255, 0.2) 0px 0px 0px 1px; transition: all var(--transition-base); position: relative; }

.glass::before { content: ""; position: absolute; inset: 0px; border-radius: inherit; background: linear-gradient(135deg, rgba(255, 255, 255, 0.4) 0%, transparent 50%, rgba(255, 255, 255, 0.1) 100%); opacity: 0.6; pointer-events: none; }

.glass:hover { background: linear-gradient(135deg, rgba(255, 255, 255, 0.35) 0%, rgba(255, 255, 255, 0.2) 100%); border-color: rgba(255, 255, 255, 0.55); box-shadow: rgba(31, 38, 135, 0.2) 0px 12px 48px, rgba(255, 255, 255, 0.15) 0px 6px 24px, rgba(255, 255, 255, 0.7) 0px 2px 6px inset, rgba(0, 0, 0, 0.1) 0px -3px 8px inset; transform: translateZ(0px) scale(1.005); }

.btn-primary { background: linear-gradient(135deg, var(--primary-blue) 0%, var(--primary-blue-dark) 100%); color: white; border: none; padding: 16px 48px; border-radius: 50px; font-size: 1rem; font-weight: 600; cursor: pointer; box-shadow: rgba(91, 143, 255, 0.4) 0px 8px 24px, rgba(255, 255, 255, 0.3) 0px 1px 2px inset, rgba(0, 0, 0, 0.1) 0px -2px 4px inset; transition: all var(--transition-base); display: inline-block; position: relative; overflow: hidden; user-select: none; -webkit-tap-highlight-color: transparent; }

.btn-primary::before { content: ""; position: absolute; top: 0px; left: -100%; width: 100%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent); transition: left var(--transition-slow); }

.btn-primary::after { content: ""; position: absolute; inset: 0px; border-radius: 50px; padding: 1px; background: linear-gradient(135deg, rgba(255, 255, 255, 0.4), transparent); mask: linear-gradient(rgb(255, 255, 255) 0px, rgb(255, 255, 255) 0px) content-box exclude, linear-gradient(rgb(255, 255, 255) 0px, rgb(255, 255, 255) 0px); opacity: 0.8; }

.btn-primary:hover::before { left: 100%; }

.btn-primary:hover { transform: translateY(-3px) scale(1.02); box-shadow: rgba(91, 143, 255, 0.5) 0px 16px 40px, rgba(255, 255, 255, 0.4) 0px 1px 3px inset; }

.btn-primary:active { transform: translateY(-1px) scale(1.01); box-shadow: rgba(91, 143, 255, 0.4) 0px 8px 24px, rgba(0, 0, 0, 0.15) 0px 2px 4px inset; }

.btn-primary:focus-visible { outline: rgba(91, 143, 255, 0.5) solid 3px; outline-offset: 3px; }

.icon-group { display: flex; gap: 8px; align-items: center; margin-bottom: 24px; }

.btn-icon-group { display: flex; gap: 12px; padding: 8px 12px; border-radius: 50px; }

.btn-icon { width: 44px; height: 44px; border-radius: 14px; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all var(--transition-base); color: var(--text-secondary); background: linear-gradient(135deg, rgba(255, 255, 255, 0.2) 0%, rgba(255, 255, 255, 0.1) 100%); box-shadow: rgba(0, 0, 0, 0.08) 0px 4px 12px, rgba(255, 255, 255, 0.4) 0px 1px 2px inset; position: relative; overflow: hidden; user-select: none; -webkit-tap-highlight-color: transparent; }

.btn-icon::before { content: ""; position: absolute; inset: 0px; background: radial-gradient(circle, rgba(255, 255, 255, 0.2), transparent 70%); opacity: 0; transition: opacity var(--transition-base); }

.btn-icon:hover::before { opacity: 1; }

.btn-icon:hover { transform: scale(1.08) translateY(-2px); color: var(--text-primary); background: rgba(255, 255, 255, 0.2); box-shadow: var(--shadow-md); }

.btn-icon:active { transform: scale(1.02); }

.btn-icon:focus-visible { outline: rgba(91, 143, 255, 0.5) solid 2px; outline-offset: 2px; }

.btn-avatar { width: 56px; height: 56px; border-radius: 50%; background: linear-gradient(135deg, var(--primary-teal) 0%, var(--primary-teal-dark) 100%); border: none; cursor: pointer; box-shadow: rgba(109, 216, 208, 0.4) 0px 8px 24px, rgba(255, 255, 255, 0.4) 0px 1px 2px inset, rgba(0, 0, 0, 0.1) 0px -2px 4px inset, rgba(255, 255, 255, 0.6) 0px 0px 0px 3px; transition: all var(--transition-base); position: relative; overflow: hidden; user-select: none; -webkit-tap-highlight-color: transparent; }

.btn-avatar::before { content: "👤"; font-size: 26px; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); filter: drop-shadow(rgba(0, 0, 0, 0.2) 0px 1px 2px); }

.btn-avatar::after { content: ""; position: absolute; inset: -50%; background: radial-gradient(circle, rgba(255, 255, 255, 0.3), transparent 60%); opacity: 0; transition: opacity var(--transition-base); }

.btn-avatar:hover::after { opacity: 1; }

.btn-avatar:hover { transform: translateY(-4px) scale(1.08); box-shadow: rgba(109, 216, 208, 0.6) 0px 16px 40px, rgba(255, 255, 255, 0.8) 0px 0px 0px 3px; }

.btn-avatar:active { transform: translateY(-2px) scale(1.04); }

.btn-avatar:focus-visible { outline: rgba(109, 216, 208, 0.5) solid 3px; outline-offset: 3px; }

.search-wrapper { position: relative; margin-bottom: 16px; }

.search-wrapper .glass { border-radius: 28px; }

.search-input { width: 100%; padding: 18px 60px 18px 56px; border-radius: 28px; border: none; font-size: 0.95rem; color: var(--text-primary); outline: none; transition: all var(--transition-base); background: transparent; }

.search-input::placeholder { color: var(--text-secondary); transition: color var(--transition-base); }

